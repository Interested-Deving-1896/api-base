APP_ENV=development
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=backend
DB_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

RATELIMIT_PER_IP_HOURLY=1000

# Storage
# STORAGE_PROVIDER picks the default. Other providers below are still loaded
# if their env is set, so individual services can opt into them via the registry.
STORAGE_PROVIDER=local

# Local (always available; defaults shown)
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_BASE_URL=/files

# S3 (loaded only if STORAGE_S3_BUCKET is set)
# Omit access/secret keys to fall back to the AWS credential chain (IAM role, ~/.aws, etc.)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_ENDPOINT=

# Cloudflare R2 (loaded only if STORAGE_R2_ACCOUNT_ID is set)
STORAGE_R2_ACCOUNT_ID=
STORAGE_R2_BUCKET=
STORAGE_R2_ACCESS_KEY=
STORAGE_R2_SECRET_KEY=
STORAGE_R2_PUBLIC_URL=

# Payments
# Same rule as storage: defaults pick the active processor; others load if their
# keys are present.
PAYMENT_CARD_PROVIDER=stripe
PAYMENT_MOBILE_MONEY_PROVIDER=paystack

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
