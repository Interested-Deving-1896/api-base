// Package repository is the data-access layer for the {{.NameLower}} module. It
// translates domain.{{.NamePascal}} values to/from rows in the {{.NamePlural}} table.
//
// The Repository interface is what the service depends on. Tests can
// provide a mock implementation; production uses the real sqlx-backed one.
//
// Error translation happens here: sql.ErrNoRows becomes apierror.ErrNotFound,
// and unique violations become apierror.ErrConflict. The service and
// handler layers don't need to know about SQL details.
package repository

import (
	"context"
	"database/sql"
	"errors"
	"time"

	"github.com/jmoiron/sqlx"
	"github.com/lib/pq"
	"{{.ModulePath}}/internal/modules/{{.NameLower}}/domain"
	"{{.ModulePath}}/internal/shared/apierror"
)

type Repository interface {
	Create(ctx context.Context, t *domain.{{.NamePascal}}) error
	GetByID(ctx context.Context, id string) (*domain.{{.NamePascal}}, error)
}

type repo struct {
	db *sqlx.DB
}

func New(db *sqlx.DB) Repository {
	return &repo{db: db}
}

type {{.NameLower}}Row struct {
	ID        string    `db:"id"`
	CreatedAt time.Time `db:"created_at"`
	UpdatedAt time.Time `db:"updated_at"`
}

func (r *repo) Create(ctx context.Context, t *domain.{{.NamePascal}}) error {
	_, err := r.db.ExecContext(ctx, `
		INSERT INTO {{.NamePlural}} (id, created_at, updated_at)
		VALUES ($1, $2, $3)
	`, t.ID, t.CreatedAt, t.UpdatedAt)
	if err != nil {
		var pqErr *pq.Error
		if errors.As(err, &pqErr) && pqErr.Code == "23505" {
			return apierror.ErrConflict
		}
		return err
	}
	return nil
}

func (r *repo) GetByID(ctx context.Context, id string) (*domain.{{.NamePascal}}, error) {
	var row {{.NameLower}}Row
	err := r.db.GetContext(ctx, &row, `
		SELECT id, created_at, updated_at
		FROM {{.NamePlural}} WHERE id = $1
	`, id)
	if err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, apierror.ErrNotFound
		}
		return nil, err
	}
	return &domain.{{.NamePascal}}{
		ID:        row.ID,
		CreatedAt: row.CreatedAt,
		UpdatedAt: row.UpdatedAt,
	}, nil
}
